#!/usr/bin/env bash
set -euo pipefail

APP_NAME="opencode-profile-kit"
CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"

CONFIG_DIR="$CONFIG_HOME/$APP_NAME"
CONFIG_FILE="$CONFIG_DIR/config.env"
DATA_DIR="$DATA_HOME/$APP_NAME"
STATE_DIR="$DATA_DIR/state"
PROFILES_DB="$STATE_DIR/profiles.tsv"
BINS_DB="$STATE_DIR/bins.tsv"
BIN_LAUNCHER_MARKER="# generated by opencode-profile-kit"

OC_GLOBAL_DIR="$HOME/.config/opencode"
OC_PROFILES_DIR="${OC_PROFILES_DIR:-$HOME/.opencode-profiles}"
OC_BIN_DIR="${OC_BIN_DIR:-$HOME/.local/bin}"
OC_RUNTIME_IGNORE_DEFAULT="session tmp logs semantic index cache .cache"

if [[ -f "$CONFIG_FILE" ]]; then
  # shellcheck disable=SC1090
  source "$CONFIG_FILE"
fi

now_utc() { date -u +%Y-%m-%dT%H:%M:%SZ; }

usage() {
  cat <<'USAGE'
Usage:
  ocp new <profile> [--from <template>]       Create a profile
  ocp clone <src> <dst> [--full]              Clone a profile
  ocp rename <old> <new>                      Rename a profile
  ocp remove <profile> [--delete-dir]         Remove a profile

  ocp run <profile> [opencode args...]        Run opencode with OPENCODE_CONFIG_DIR
  ocp exec <profile> -- <command...>          Run any command with OPENCODE_CONFIG_DIR

  ocp env <profile> [bash|zsh]                Print shell env export
  ocp clear [bash|zsh]                        Print shell env unset
  ocp which                                   Show current profile from OPENCODE_CONFIG_DIR

  ocp link <profile> <path> [--force]         Symlink global config path into profile
  ocp link-all <path> [--force]               Symlink global config path into all profiles

  ocp bin create <profile> <command-name>     Create a launcher command for a profile
  ocp bin list [profile]                      List launcher commands
  ocp bin remove <command-name>               Remove a launcher command
  ocp bin repair <command-name|--all>         Rebuild launcher command scripts

  ocp capture <profile> -- <command...>       Capture global installer changes into a profile
  ocp rewrite-paths <profile> [path-suffix]   Rewrite hardcoded OpenCode paths in markdown files

  ocp list                                    List profiles
  ocp path <profile>                          Print profile path
  ocp refresh                                 Rebuild registry from profile dirs
  ocp doctor [profile]                        Check installation/profile health
  ocp completion [bash|zsh] [--install]       Print/install shell completion
  ocp config                                  Print resolved paths
USAGE
}

fail() { echo "ocp: $*" >&2; exit 1; }
ensure_state() { mkdir -p "$STATE_DIR"; touch "$PROFILES_DB" "$BINS_DB"; }

current_cli_name() {
  basename "$0"
}

require_opencode() {
  if ! command -v opencode >/dev/null 2>&1; then
    cat >&2 <<'EOF'
error: opencode is not installed or not found in PATH

Install OpenCode first:

  https://opencode.ai/docs

After installation, make sure this works:

  opencode --help
EOF
    exit 1
  fi
}

require_rsync() {
  if ! command -v rsync >/dev/null 2>&1; then
    cat >&2 <<'EOF'
error: rsync is required for ocp capture

Install rsync first:

  Ubuntu/Debian:
    sudo apt update && sudo apt install -y rsync

  macOS:
    brew install rsync

  Arch:
    sudo pacman -S rsync

  Fedora:
    sudo dnf install rsync
EOF
    exit 1
  fi
}

expand_home_path() {
  local path="$1"

  case "$path" in
    "~")
      printf '%s\n' "$HOME"
      ;;
    "~/"*)
      printf '%s/%s\n' "$HOME" "${path#"~/"}"
      ;;
    "\$HOME")
      printf '%s\n' "$HOME"
      ;;
    "\$HOME/"*)
      printf '%s/%s\n' "$HOME" "${path#"\$HOME/"}"
      ;;
    "\${HOME}")
      printf '%s\n' "$HOME"
      ;;
    "\${HOME}/"*)
      printf '%s/%s\n' "$HOME" "${path#"\${HOME}/"}"
      ;;
    *)
      printf '%s\n' "$path"
      ;;
  esac
}

resolve_profiles_dir() {
  local dir
  dir="$(expand_home_path "$OC_PROFILES_DIR")"

  case "$dir" in
    "$HOME"/*) ;;
    *)
      cat >&2 <<EOF
error: OC_PROFILES_DIR must be under HOME

HOME:
  $HOME

OC_PROFILES_DIR:
  $OC_PROFILES_DIR

This tool expects profile directories to live under HOME so paths can be rewritten safely and predictably.
EOF
      exit 1
      ;;
  esac

  printf '%s\n' "$dir"
}

profiles_dir_suffix() {
  local profiles_dir
  profiles_dir="$(resolve_profiles_dir)"

  printf '%s\n' "${profiles_dir#"$HOME"}"
}

profile_replacement_suffix() {
  local profile="$1"
  printf '%s/%s\n' "$(profiles_dir_suffix)" "$profile"
}

ensure_profile_name() {
  local p="${1:-}"
  [[ -n "$p" ]] || fail "profile is required"
  [[ "$p" =~ ^[a-zA-Z0-9._-]+$ ]] || fail "invalid profile name: $p"
}

ensure_command_name() {
  local n="${1:-}"
  [[ -n "$n" ]] || fail "command name is required"
  [[ "$n" =~ ^[a-zA-Z0-9._-]+$ ]] || fail "invalid command name: $n"
}

manifest_path() { echo "$1/.ocp-profile.json"; }

write_manifest() {
  local dir="$1" name="$2" template="${3:-}" force="${4:-0}" manifest created_at template_json
  manifest="$(manifest_path "$dir")"
  [[ -f "$manifest" && "$force" != "1" ]] && return 0

  created_at="$(now_utc)"
  if [[ -n "$template" ]]; then
    template_json="\"$template\""
  else
    template_json="null"
  fi

  cat > "$manifest" <<JSON
{
  "name": "$name",
  "created_at": "$created_at",
  "template": $template_json,
  "runtime_ignore": ["session", "tmp", "logs", "semantic", "index", "cache", ".cache"]
}
JSON
}

with_state_lock() {
  ensure_state

  local lock_dir="$STATE_DIR/.lock"
  local waited=0

  while ! mkdir "$lock_dir" 2>/dev/null; do
    waited=$((waited + 1))

    if (( waited >= 100 )); then
      echo "error: timed out waiting for state lock: $lock_dir" >&2
      exit 1
    fi

    sleep 0.1
  done

  local status=0
  "$@" || status=$?

  rmdir "$lock_dir"
  return "$status"
}

_register_profile_locked() {
  local profile="$1"
  local dir="$2"
  local created_at="${3:-}"

  if [[ -z "$created_at" && -f "$PROFILES_DB" ]]; then
    created_at="$(awk -F '\t' -v p="$profile" '$1 == p { print $3; exit }' "$PROFILES_DB")"
  fi

  [[ -n "$created_at" ]] || created_at="$(now_utc)"

  local tmp
  tmp="$(mktemp "${PROFILES_DB}.tmp.XXXXXX")"

  awk -F '\t' -v p="$profile" '$1 != p' "$PROFILES_DB" > "$tmp" || true
  printf '%s\t%s\t%s\n' "$profile" "$dir" "$created_at" >> "$tmp"
  mv "$tmp" "$PROFILES_DB"
}

register_profile() {
  with_state_lock _register_profile_locked "$@"
}

_unregister_profile_locked() {
  local profile="$1"

  local tmp
  tmp="$(mktemp "${PROFILES_DB}.tmp.XXXXXX")"

  awk -F '\t' -v p="$profile" '$1 != p' "$PROFILES_DB" > "$tmp" || true
  mv "$tmp" "$PROFILES_DB"
}

unregister_profile() {
  with_state_lock _unregister_profile_locked "$@"
}

profile_lookup_path() {
  local profile="$1" path fallback
  ensure_state
  path="$(awk -F '\t' -v p="$profile" '$1 == p {print $2; found=1; exit} END {if (!found) exit 1}' "$PROFILES_DB" 2>/dev/null || true)"
  [[ -n "$path" ]] && { echo "$path"; return 0; }
  local profiles_dir
  profiles_dir="$(resolve_profiles_dir)"
  fallback="$profiles_dir/$profile"
  [[ -d "$fallback" ]] && echo "$fallback"
}

require_profile_path() {
  local profile="$1" dir
  ensure_profile_name "$profile"
  dir="$(profile_lookup_path "$profile")"
  [[ -n "$dir" && -d "$dir" ]] || fail "profile does not exist: $profile"
  echo "$dir"
}

copy_profile() {
  local src="$1" dst="$2" full="$3"
  mkdir -p "$dst"
  if command -v rsync >/dev/null 2>&1; then
    if [[ "$full" == "1" ]]; then
      rsync -a "$src/" "$dst/"
    else
      rsync -a --exclude session --exclude tmp --exclude logs --exclude semantic --exclude index --exclude cache --exclude .cache "$src/" "$dst/"
    fi
  else
    (cd "$src" && tar cf - .) | (cd "$dst" && tar xpf -)
    if [[ "$full" != "1" ]]; then
      rm -rf "$dst/session" "$dst/tmp" "$dst/logs" "$dst/semantic" "$dst/index" "$dst/cache" "$dst/.cache"
    fi
  fi
}

cmd_new() {
  local profile="${1:-}" template=""
  shift || true
  ensure_profile_name "$profile"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --from)
        template="${2:-}"
        [[ -n "$template" ]] || fail "template profile is required"
        shift 2
        ;;
      *) fail "unknown option for new: $1" ;;
    esac
  done

  local profiles_dir profile_dir existed=0
  profiles_dir="$(resolve_profiles_dir)"
  profile_dir="$profiles_dir/$profile"

  if [[ -e "$profile_dir" && ! -d "$profile_dir" ]]; then
    fail "path exists and is not a directory: $profile_dir"
  fi

  if [[ -d "$profile_dir" ]]; then
    existed=1
    echo "profile directory already exists: $profile_dir"
  else
    mkdir -p "$profile_dir"
    echo "created profile directory: $profile_dir"
  fi

  if [[ -n "$template" && "$existed" == "0" ]]; then
    copy_profile "$(require_profile_path "$template")" "$profile_dir" 0
  elif [[ -n "$template" && "$existed" == "1" ]]; then
    echo "profile directory already exists; skipping template copy: $template"
  fi

  write_manifest "$profile_dir" "$profile" "$template" "$((1 - existed))"
  register_profile "$profile" "$profile_dir"
  echo "created: $profile -> $profile_dir"
}

cmd_clone() {
  local src_profile="${1:-}" dst_profile="${2:-}" full=0
  shift 2 || true
  ensure_profile_name "$src_profile"; ensure_profile_name "$dst_profile"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --full) full=1; shift ;;
      *) fail "unknown option for clone: $1" ;;
    esac
  done
  local src dst
  local profiles_dir
  profiles_dir="$(resolve_profiles_dir)"
  src="$(require_profile_path "$src_profile")"
  dst="$profiles_dir/$dst_profile"
  [[ ! -e "$dst" ]] || fail "destination already exists: $dst"
  copy_profile "$src" "$dst" "$full"
  write_manifest "$dst" "$dst_profile" "$src_profile" 1
  register_profile "$dst_profile" "$dst"
  echo "cloned: $src_profile -> $dst_profile"
}

_rename_profile_locked() {
  local old="$1" new="$2" old_dir="$3" new_dir="$4" created_at tmp

  mv "$old_dir" "$new_dir"

  created_at="$(awk -F '\t' -v p="$old" '$1 == p { print $3; exit }' "$PROFILES_DB" 2>/dev/null || true)"
  [[ -n "$created_at" ]] || created_at="$(now_utc)"

  tmp="$(mktemp "${PROFILES_DB}.tmp.XXXXXX")"
  awk -F '\t' -v p="$old" '$1 != p' "$PROFILES_DB" > "$tmp" || true
  printf '%s\t%s\t%s\n' "$new" "$new_dir" "$created_at" >> "$tmp"
  mv "$tmp" "$PROFILES_DB"

  tmp="$(mktemp "${BINS_DB}.tmp.XXXXXX")"
  awk -F '\t' -v old="$old" -v new="$new" 'BEGIN { OFS = FS } $2 == old { $2 = new } { print }' "$BINS_DB" > "$tmp" || true
  mv "$tmp" "$BINS_DB"
}

rewrite_manifest_name() {
  local manifest="$1" name="$2" tmp
  tmp="$(mktemp "${manifest}.tmp.XXXXXX")"

  if grep -Eq '"name"[[:space:]]*:' "$manifest"; then
    awk -v n="$name" '
      /"name"[[:space:]]*:/ && !done {
        sub(/"name"[[:space:]]*:[[:space:]]*"[^"]*"/, "\"name\": \"" n "\"")
        done=1
      }
      { print }
      END { if (!done) exit 1 }
    ' "$manifest" > "$tmp" || { rm -f "$tmp"; fail "could not rewrite manifest: $manifest"; }
  else
    awk -v n="$name" '
      !done && match($0, /\{/) {
        print substr($0, 1, RSTART)
        print "  \"name\": \"" n "\","
        rest=substr($0, RSTART + 1)
        if (rest != "") {
          print rest
        }
        done=1
        next
      }
      { print }
      END { if (!done) exit 1 }
    ' "$manifest" > "$tmp" || { rm -f "$tmp"; fail "could not rewrite manifest: $manifest"; }
  fi

  mv "$tmp" "$manifest" || { rm -f "$tmp"; fail "could not rewrite manifest: $manifest"; }
}

path_parent_writable_or_creatable() {
  local path="$1" parent
  parent="$(dirname "$path")"

  while [[ ! -e "$parent" ]]; do
    [[ "$parent" != "/" && "$parent" != "." ]] || break
    parent="$(dirname "$parent")"
  done

  [[ -d "$parent" && -w "$parent" && -x "$parent" ]]
}

directory_allows_temp_file() {
  local dir="$1" tmp
  tmp="$(mktemp "$dir/.ocp-preflight.XXXXXX" 2>/dev/null)" || return 1
  rm -f "$tmp"
}

preflight_manifest_for_profile_rename() {
  local old_dir="$1" manifest
  manifest="$(manifest_path "$old_dir")"

  if [[ -f "$manifest" ]]; then
    [[ -w "$manifest" ]] || fail "manifest is not writable: $manifest"
    directory_allows_temp_file "$old_dir" || fail "manifest directory cannot create temporary files: $old_dir"
  else
    directory_allows_temp_file "$old_dir" || fail "manifest cannot be created in profile directory: $old_dir"
  fi
}

preflight_bins_for_profile_rename() {
  local profile="$1" name row_profile path
  ensure_state
  while IFS=$'\t' read -r name row_profile path; do
    [[ "$row_profile" == "$profile" ]] || continue
    if [[ -e "$path" || -L "$path" ]]; then
      grep -Fq "$BIN_LAUNCHER_MARKER" "$path" 2>/dev/null || fail "refusing to repair unmanaged launcher: $path"
      [[ -w "$path" ]] || fail "launcher is not writable: $path"
    else
      path_parent_writable_or_creatable "$path" || fail "launcher parent is not writable or creatable: $(dirname "$path")"
    fi
  done < "$BINS_DB"
}

repair_bins_for_profile() {
  local profile="$1" name row_profile path self
  ensure_state
  self="$(resolve_self_path)"
  while IFS=$'\t' read -r name row_profile path; do
    [[ "$row_profile" == "$profile" ]] || continue
    mkdir -p "$(dirname "$path")"
    if [[ -e "$path" || -L "$path" ]]; then
      grep -Fq "$BIN_LAUNCHER_MARKER" "$path" 2>/dev/null || fail "refusing to repair unmanaged launcher: $path"
    fi
    write_bin_launcher "$profile" "$path" "$self"
  done < "$BINS_DB"
}

warn_old_profile_paths() {
  local dir="$1" old_dir="$2" matches
  matches="$(grep -rIl \
    --include='*.md' \
    --exclude-dir='.git' \
    --exclude-dir='session' \
    --exclude-dir='tmp' \
    --exclude-dir='logs' \
    --exclude-dir='semantic' \
    --exclude-dir='index' \
    --exclude-dir='cache' \
    --exclude-dir='.cache' \
    -- "$old_dir" "$dir" 2>/dev/null || true)"
  if [[ -n "$matches" ]]; then
    echo "warning: hardcoded path references may remain after rename:"
    echo "$matches"
    echo "warning: rerun installers, run rewrite-paths where appropriate, or use ocp upgrade when available"
  fi
}

cmd_rename() {
  local old="${1:-}" new="${2:-}" old_dir new_dir profiles_dir manifest
  shift 2 || true
  [[ $# -eq 0 ]] || fail "usage: ocp rename <old> <new>"
  ensure_profile_name "$old"
  ensure_profile_name "$new"
  [[ "$old" != "$new" ]] || fail "new profile name must differ from old profile name"

  old_dir="$(require_profile_path "$old")"
  profiles_dir="$(resolve_profiles_dir)"
  new_dir="$profiles_dir/$new"
  [[ ! -e "$new_dir" ]] || fail "destination already exists: $new_dir"
  preflight_bins_for_profile_rename "$old"
  preflight_manifest_for_profile_rename "$old_dir"

  with_state_lock _rename_profile_locked "$old" "$new" "$old_dir" "$new_dir"

  manifest="$(manifest_path "$new_dir")"
  if [[ -f "$manifest" ]]; then
    rewrite_manifest_name "$manifest" "$new"
  else
    write_manifest "$new_dir" "$new" "" 1
  fi

  repair_bins_for_profile "$new"
  warn_old_profile_paths "$new_dir" "$old_dir"
  echo "renamed: $old -> $new"
}

cmd_remove() {
  local profile="${1:-}" delete_dir=0 dir
  shift || true
  ensure_profile_name "$profile"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --delete-dir) delete_dir=1; shift ;;
      *) fail "unknown option for remove: $1" ;;
    esac
  done
  dir="$(profile_lookup_path "$profile")"
  unregister_profile "$profile"
  if [[ "$delete_dir" == "1" && -n "$dir" ]]; then rm -rf "$dir"; echo "removed: $profile and deleted $dir"; else echo "removed from registry: $profile"; fi
}

cmd_run() {
  local profile="${1:-}" dir;
  shift || true;

  require_opencode

  dir="$(require_profile_path "$profile")";
  export OPENCODE_CONFIG_DIR="$dir";
  exec opencode "$@";
}

cmd_shell() {
  local profile="${1:-}" dir shell_name
  shift || true
  [[ $# -eq 0 ]] || fail "usage: ocp shell <profile>"

  dir="$(require_profile_path "$profile")"
  export OPENCODE_CONFIG_DIR="$dir"
  cd "$dir"
  shell_name="${SHELL:-/bin/sh}"
  exec "$shell_name"
}

run_stdin_script() {
  local tmp_dir script status=0
  tmp_dir="$(mktemp -d)" || return 1
  script="$tmp_dir/stdin-script.sh"

  cat > "$script" || { rm -rf "$tmp_dir"; return 1; }
  bash "$script" || status=$?
  rm -rf "$tmp_dir"
  return "$status"
}

cmd_exec() {
  local profile="${1:-}" dir
  shift || true

  dir="$(require_profile_path "$profile")"
  export OPENCODE_CONFIG_DIR="$dir"

  case "${1:-}" in
    --stdin)
      shift
      [[ $# -eq 0 ]] || fail "usage: ocp exec <profile> --stdin"
      (cd "$dir" && run_stdin_script)
      ;;
    --)
      shift
      [[ $# -gt 0 ]] || fail "command is required"
      exec "$@"
      ;;
    *)
      fail "usage: ocp exec <profile> -- <command...> OR ocp exec <profile> --stdin"
      ;;
  esac
}

cmd_env() {
  local profile="${1:-}" shell="${2:-bash}" dir
  dir="$(require_profile_path "$profile")"
  case "$shell" in bash|zsh|sh) printf 'export OPENCODE_CONFIG_DIR=%q\n' "$dir" ;; *) fail "unsupported shell: $shell" ;; esac
}

cmd_clear() { case "${1:-bash}" in bash|zsh|sh) echo 'unset OPENCODE_CONFIG_DIR' ;; *) fail "unsupported shell: ${1:-}" ;; esac; }

cmd_which() {
  local current="${OPENCODE_CONFIG_DIR:-}" name
  [[ -n "$current" ]] || fail "OPENCODE_CONFIG_DIR is not set"
  ensure_state
  name="$(awk -F '\t' -v d="$current" '$2 == d {print $1; found=1; exit} END {if (!found) exit 1}' "$PROFILES_DB" 2>/dev/null || true)"
  [[ -n "$name" ]] && echo "$name" || echo "$current"
}

link_one() {
  local profile="$1" rel="$2" force="$3" dir src dst
  dir="$(require_profile_path "$profile")"; src="$OC_GLOBAL_DIR/$rel"; dst="$dir/$rel"
  [[ -e "$src" || -L "$src" ]] || fail "source does not exist: $src"
  mkdir -p "$(dirname "$dst")"
  if [[ -e "$dst" || -L "$dst" ]]; then
    [[ "$force" == "1" ]] || fail "destination exists: $dst; use --force"
    rm -rf "$dst"
  fi
  ln -s "$src" "$dst"
  echo "linked: $dst -> $src"
}

cmd_link() {
  local profile="${1:-}" rel="${2:-}" force=0
  shift 2 || true; ensure_profile_name "$profile"; [[ -n "$rel" ]] || fail "path is required"
  while [[ $# -gt 0 ]]; do case "$1" in --force) force=1; shift ;; *) fail "unknown option for link: $1" ;; esac; done
  link_one "$profile" "$rel" "$force"
}

cmd_link_all() {
  local rel="${1:-}" force=0 profile
  shift || true; [[ -n "$rel" ]] || fail "path is required"
  while [[ $# -gt 0 ]]; do case "$1" in --force) force=1; shift ;; *) fail "unknown option for link-all: $1" ;; esac; done
  while IFS= read -r profile; do link_one "$profile" "$rel" "$force"; done < <(cmd_list)
}

_register_bin_locked() {
  local name="$1" profile="$2" path="$3"

  local tmp
  tmp="$(mktemp "${BINS_DB}.tmp.XXXXXX")"

  awk -F '	' -v n="$name" '$1 != n' "$BINS_DB" > "$tmp" || true
  printf '%s	%s	%s
' "$name" "$profile" "$path" >> "$tmp"
  mv "$tmp" "$BINS_DB"
}

register_bin() {
  with_state_lock _register_bin_locked "$@"
}

_unregister_bin_locked() {
  local name="$1"
  local tmp
  tmp="$(mktemp "${BINS_DB}.tmp.XXXXXX")"
  awk -F '\t' -v n="$name" '$1 != n' "$BINS_DB" > "$tmp" || true
  mv "$tmp" "$BINS_DB"
}

unregister_bin() {
  with_state_lock _unregister_bin_locked "$@"
}

bin_lookup() {
  local name="$1"
  ensure_state
  awk -F '\t' -v n="$name" '$1 == n { print $1 "\t" $2 "\t" $3; found=1; exit } END { if (!found) exit 1 }' "$BINS_DB" 2>/dev/null || true
}

write_bin_launcher() {
  local profile="$1" launcher="$2" self="$3" self_quoted
  printf -v self_quoted '%q' "$self"

  cat > "$launcher" <<BIN
#!/usr/bin/env bash
$BIN_LAUNCHER_MARKER
exec $self_quoted run "$profile" "\$@"
BIN
  chmod +x "$launcher"
}

resolve_self_path() {
  local self dir base
  self="$(command -v "$0" 2>/dev/null || true)"
  [[ -n "$self" && -x "$self" ]] || self="$0"

  if [[ "$self" == */* ]]; then
    dir="$(cd "$(dirname "$self")" && pwd -P)" || return 1
    base="$(basename "$self")"
    printf '%s/%s\n' "$dir" "$base"
  else
    command -v "$self"
  fi
}

cmd_bin_create() {
  local profile="${1:-}" name="${2:-}" dir launcher self
  ensure_profile_name "$profile"
  ensure_command_name "$name"
  dir="$(require_profile_path "$profile")"
  mkdir -p "$OC_BIN_DIR"
  launcher="$OC_BIN_DIR/$name"
  [[ ! -e "$launcher" && ! -L "$launcher" ]] || fail "launcher already exists: $launcher"
  self="$(resolve_self_path)"
  write_bin_launcher "$profile" "$launcher" "$self"
  register_bin "$name" "$profile" "$launcher"
  echo "created: $launcher -> $profile ($dir)"
}

cmd_bin_list() {
  local filter="${1:-}"
  ensure_state
  if [[ -n "$filter" ]]; then
    ensure_profile_name "$filter"
    require_profile_path "$filter" >/dev/null
  fi
  awk -F '\t' -v p="$filter" 'NF >= 3 && (p == "" || $2 == p) { print $1 "\t" $2 "\t" $3 }' "$BINS_DB"
}

cmd_bin_remove() {
  local name="${1:-}" row path
  ensure_command_name "$name"
  row="$(bin_lookup "$name")"
  [[ -n "$row" ]] || fail "bin command is not registered: $name"
  path="$(printf '%s\n' "$row" | awk -F '\t' '{ print $3 }')"
  if [[ -e "$path" || -L "$path" ]]; then
    grep -Fq "$BIN_LAUNCHER_MARKER" "$path" 2>/dev/null || fail "refusing to remove unmanaged launcher: $path"
    rm -f "$path"
  fi
  unregister_bin "$name"
  echo "removed: $name"
}

cmd_bin_repair_one() {
  local name="$1" row profile path self
  row="$(bin_lookup "$name")"
  [[ -n "$row" ]] || fail "bin command is not registered: $name"
  profile="$(printf '%s\n' "$row" | awk -F '\t' '{ print $2 }')"
  path="$(printf '%s\n' "$row" | awk -F '\t' '{ print $3 }')"
  require_profile_path "$profile" >/dev/null
  mkdir -p "$(dirname "$path")"
  if [[ -e "$path" || -L "$path" ]]; then
    grep -Fq "$BIN_LAUNCHER_MARKER" "$path" 2>/dev/null || fail "refusing to repair unmanaged launcher: $path"
  fi
  self="$(resolve_self_path)"
  write_bin_launcher "$profile" "$path" "$self"
  echo "repaired: $name -> $profile"
}

cmd_bin_repair() {
  local target="${1:-}"
  if [[ "$target" == "--all" ]]; then
    ensure_state
    while IFS=$'\t' read -r name _profile _path; do
      [[ -n "$name" ]] || continue
      cmd_bin_repair_one "$name"
    done < "$BINS_DB"
  else
    ensure_command_name "$target"
    cmd_bin_repair_one "$target"
  fi
}

cmd_bin() {
  local sub="${1:-}"
  shift || true
  case "$sub" in
    create)
      [[ $# -eq 2 ]] || fail "usage: ocp bin create <profile> <command-name>"
      cmd_bin_create "$@"
      ;;
    list)
      [[ $# -le 1 ]] || fail "usage: ocp bin list [profile]"
      cmd_bin_list "${1:-}"
      ;;
    remove)
      [[ $# -eq 1 ]] || fail "usage: ocp bin remove <command-name>"
      cmd_bin_remove "$1"
      ;;
    repair)
      [[ $# -eq 1 ]] || fail "usage: ocp bin repair <command-name|--all>"
      cmd_bin_repair "$1"
      ;;
    "") fail "usage: ocp bin create|list|remove|repair ..." ;;
    *)
      if [[ $# -eq 1 ]]; then
        cmd_bin_create "$sub" "$1"
      else
        fail "usage: ocp bin create <profile> <command-name>"
      fi
      ;;
  esac
}

cmd_list() {
  ensure_state
  awk -F '\t' 'NF >= 2 {print $1 "\t" $2}' "$PROFILES_DB" | while IFS=$'\t' read -r p d; do [[ -d "$d" ]] && echo "$p"; done
}
cmd_path() { require_profile_path "${1:-}"; }

_refresh_locked() {
  local tmp dir profile created profiles_dir
  tmp="$(mktemp "${PROFILES_DB}.tmp.XXXXXX")"
  profiles_dir="$(resolve_profiles_dir)"

  if [[ -d "$profiles_dir" ]]; then
    for dir in "$profiles_dir"/*; do
      [[ -d "$dir" ]] || continue
      profile="$(basename "$dir")"
      created="$(awk -F '	' -v p="$profile" '$1 == p { print $3; exit }' "$PROFILES_DB" 2>/dev/null || true)"
      [[ -n "$created" ]] || created="$(now_utc)"
      printf '%s	%s	%s
' "$profile" "$dir" "$created" >> "$tmp"
      [[ -f "$(manifest_path "$dir")" ]] || write_manifest "$dir" "$profile" ""
    done
  fi

  mv "$tmp" "$PROFILES_DB"
}

cmd_refresh() {
  with_state_lock _refresh_locked
  echo "refreshed: $PROFILES_DB"
}

check_profile() {
  local profile="$1" dir broken=0 item link
  dir="$(require_profile_path "$profile")"
  echo "profile: $profile"; echo "path: $dir"
  [[ -f "$(manifest_path "$dir")" ]] && echo "manifest: ok" || echo "manifest: missing"
  while IFS= read -r -d '' link; do
    if [[ ! -e "$link" ]]; then echo "broken symlink: $link -> $(readlink "$link")"; broken=1; fi
  done < <(find "$dir" -xtype l -print0 2>/dev/null || true)
  [[ "$broken" == "0" ]] && echo "symlinks: ok"
  for item in $OC_RUNTIME_IGNORE_DEFAULT; do [[ -e "$dir/$item" ]] && echo "runtime path present: $item" || true; done
  return 0
}

cmd_doctor() {
  local profile="${1:-}"
  local profiles_dir
  profiles_dir="$(resolve_profiles_dir)"
  echo "opencode-profile-kit";
  echo "config: $CONFIG_FILE";
  echo "state: $STATE_DIR";
  echo "profiles: $profiles_dir";
  echo "bin: $OC_BIN_DIR"
  if command -v opencode >/dev/null 2>&1; then
    echo "opencode: $(command -v opencode)"
  else
    echo "[warn] opencode: not found"
  fi
  if [[ -n "$profile" ]]; then
    check_profile "$profile";
  else
    ensure_state;
    echo "registered profiles: $(cmd_list | wc -l | tr -d ' ')";
  fi
}

cmd_capture() {
  local profile="${1:-}"
  shift || true

  local stdin_mode=0
  case "${1:-}" in
    --stdin)
      stdin_mode=1
      shift
      [[ $# -eq 0 ]] || fail "usage: ocp capture <profile> --stdin"
      ;;
    --)
      shift
      [[ $# -gt 0 ]] || fail "capture command required"
      ;;
    *)
      fail "usage: ocp capture <profile> -- <command...> OR ocp capture <profile> --stdin"
      ;;
  esac

  require_rsync

  local profile_dir
  profile_dir="$(require_profile_path "$profile")"

  local global_dir="$OC_GLOBAL_DIR"
  mkdir -p "$global_dir"

  local tmp backup_dir restored=0 status=0
  tmp="$(mktemp -d)"
  backup_dir="$tmp/backup"
  mkdir -p "$backup_dir"

  restore_global() {
    if [[ "$restored" == "0" ]]; then
      echo "[ocp] restoring global config..."
      mkdir -p "$global_dir"
      rsync -a --delete "$backup_dir/" "$global_dir/"
      restored=1
    fi
    rm -rf "$tmp"
  }

  trap restore_global EXIT INT TERM

  echo "[ocp] backing up global config..."
  rsync -a --delete "$global_dir/" "$backup_dir/"

  echo "[ocp] running installer..."
  if [[ "$stdin_mode" == "1" ]]; then
    run_stdin_script || status=$?
  else
    "$@" || status=$?
  fi

  if [[ "$status" == "0" ]]; then
    echo "[ocp] syncing changes into profile..."
    rsync -a       --exclude session       --exclude tmp       --exclude logs       --exclude semantic       --exclude index       --exclude cache       --exclude .cache       "$global_dir/"       "$profile_dir/"
  else
    echo "[ocp] installer failed with exit code: $status" >&2
  fi

  restore_global
  trap - EXIT INT TERM

  [[ "$status" == "0" ]] || exit "$status"
  echo "[ocp] done"
}


detect_shell() {
  local shell_name
  shell_name="$(basename "${SHELL:-}")"

  case "$shell_name" in
    zsh) echo "zsh" ;;
    *) echo "bash" ;;
  esac
}

cmd_completion_bash() {
  local cli_name="${1:-ocp}"

  cat <<'BASHCOMP' | sed "s/__CLI__/$cli_name/g"
___CLI___completion() {
  local cur prev cmd
  COMPREPLY=()

  cur="${COMP_WORDS[COMP_CWORD]}"
  prev="${COMP_WORDS[COMP_CWORD-1]}"
  cmd="${COMP_WORDS[1]}"

  local commands="new clone rename remove run exec env clear which link link-all bin capture rewrite-paths list path refresh doctor completion config help"

  case "$COMP_CWORD" in
    1)
      COMPREPLY=( $(compgen -W "$commands" -- "$cur") )
      return 0
      ;;
    2)
      case "$cmd" in
        run|exec|env|link|bin|capture|rewrite-paths|path|rename|remove|doctor|clone)
          local profiles
          profiles="$(__CLI__ list 2>/dev/null)"
          COMPREPLY=( $(compgen -W "$profiles" -- "$cur") )
          return 0
          ;;
        completion)
          COMPREPLY=( $(compgen -W "bash zsh --install" -- "$cur") )
          return 0
          ;;
        link-all)
          COMPREPLY=( $(compgen -f -- "$cur") )
          return 0
          ;;
      esac
      ;;
    3)
      case "$cmd" in
        new)
          COMPREPLY=( $(compgen -W "--from" -- "$cur") )
          return 0
          ;;
        clone)
          COMPREPLY=( $(compgen -W "--full" -- "$cur") )
          return 0
          ;;
        remove)
          COMPREPLY=( $(compgen -W "--delete-dir" -- "$cur") )
          return 0
          ;;
        link|link-all)
          COMPREPLY=( $(compgen -f -- "$cur") )
          return 0
          ;;
        completion)
          COMPREPLY=( $(compgen -W "--install" -- "$cur") )
          return 0
          ;;
      esac
      ;;
    4)
      case "$cmd" in
        new)
          if [[ "$prev" == "--from" ]]; then
            local profiles
            profiles="$(__CLI__ list 2>/dev/null)"
            COMPREPLY=( $(compgen -W "$profiles" -- "$cur") )
            return 0
          fi
          ;;
        link)
          COMPREPLY=( $(compgen -W "--force" -- "$cur") )
          return 0
          ;;
      esac
      ;;
    5)
      case "$cmd" in
        link)
          COMPREPLY=( $(compgen -W "--force" -- "$cur") )
          return 0
          ;;
      esac
      ;;
  esac

  return 0
}

complete -F ___CLI___completion __CLI__
BASHCOMP
}

cmd_completion_zsh() {
  local cli_name="${1:-ocp}"

  cat <<'ZSHCOMP' | sed "s/__CLI__/$cli_name/g"
#compdef __CLI__

___CLI__() {
  local -a commands profiles shells

  commands=(
    'new:Create a profile'
    'clone:Clone a profile'
    'rename:Rename a profile'
    'remove:Remove a profile'
    'run:Run opencode with a profile'
    'exec:Run a command with a profile environment'
    'env:Print shell export for a profile'
    'clear:Print shell unset for OPENCODE_CONFIG_DIR'
    'which:Show current profile'
    'link:Symlink global config path into a profile'
    'link-all:Symlink global config path into all profiles'
    'bin:Create a profile launcher command'
    'capture:Capture changes from a global-path installer'
    'rewrite-paths:Rewrite hardcoded OpenCode paths in markdown files'
    'list:List profiles'
    'path:Print profile path'
    'refresh:Rebuild profile registry'
    'doctor:Check installation/profile health'
    'completion:Print or install shell completion'
    'config:Print resolved paths'
    'help:Show help'
  )

  profiles=("${(@f)$(_call_program profiles __CLI__ list 2>/dev/null)}")
  shells=(bash zsh)

  if (( CURRENT == 2 )); then
    _describe 'command' commands
    return
  fi

  case "$words[2]" in
    run|exec|env|link|bin|capture|rewrite-paths|path|rename|remove|doctor)
      if (( CURRENT == 3 )); then
        _describe 'profile' profiles
        return
      fi
      ;;
    clone)
      if (( CURRENT == 3 )); then
        _describe 'source profile' profiles
        return
      elif (( CURRENT == 5 )); then
        _values 'clone option' '--full'
        return
      fi
      ;;
    new)
      if (( CURRENT == 4 && "$words[3]" == "--from" )); then
        _describe 'template profile' profiles
        return
      fi
      _values 'new option' '--from'
      return
      ;;
    remove)
      if (( CURRENT == 4 )); then
        _values 'remove option' '--delete-dir'
        return
      fi
      ;;
    link)
      if (( CURRENT == 5 )); then
        _values 'link option' '--force'
        return
      fi
      _files
      return
      ;;
    link-all)
      if (( CURRENT == 3 )); then
        _files
        return
      elif (( CURRENT == 4 )); then
        _values 'link-all option' '--force'
        return
      fi
      ;;
    completion)
      if (( CURRENT == 3 )); then
        _describe 'shell' shells
        _values 'completion option' '--install'
        return
      elif (( CURRENT == 4 )); then
        _values 'completion option' '--install'
        return
      fi
      ;;
  esac

  _files
}

___CLI__ "$@"
ZSHCOMP
}

cmd_completion() {
  local shell=""
  local install=0

  if [[ $# -gt 0 ]]; then
    case "$1" in
      bash|zsh)
        shell="$1"
        shift
        ;;
      --install)
        shell="$(detect_shell)"
        ;;
      *)
        echo "unknown completion shell: $1" >&2
        echo "usage: $(basename "$0") completion [bash|zsh] [--install]" >&2
        exit 1
        ;;
    esac
  else
    shell="$(detect_shell)"
  fi

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --install)
        install=1
        shift
        ;;
      *)
        echo "unknown completion option: $1" >&2
        echo "usage: $(basename "$0") completion [bash|zsh] [--install]" >&2
        exit 1
        ;;
    esac
  done

  local cli_name
  cli_name="$(current_cli_name)"

  case "$shell" in
    bash)
      if [[ "$install" == "1" ]]; then
        install_bash_completion "$cli_name"
      else
        cmd_completion_bash "$cli_name"
      fi
      ;;
    zsh)
      if [[ "$install" == "1" ]]; then
        install_zsh_completion "$cli_name"
      else
        cmd_completion_zsh "$cli_name"
      fi
      ;;
    *)
      echo "usage: $cli_name completion [bash|zsh] [--install]" >&2
      exit 1
      ;;
  esac
}


cmd_rewrite_paths() {
  local profile="${1:-}"
  local suffix="${2:-/.config/opencode}"

  ensure_profile_name "$profile"

  local profile_dir
  profile_dir="$(profile_lookup_path "$profile")"

  [[ -d "$profile_dir" ]] || {
   echo "profile not found: $profile" >&2
   exit 1
  }

  [[ "$suffix" == /.config/opencode* ]] || {
   echo "unsupported suffix: $suffix" >&2
   echo "expected: /.config/opencode or /.config/opencode/..." >&2
   exit 1
  }

  local replacement_suffix
  replacement_suffix="$(profile_replacement_suffix "$profile")"

  if [[ "$suffix" != "/.config/opencode" ]]; then
   replacement_suffix="$replacement_suffix/${suffix#/.config/opencode/}"
  fi

  echo "[ocp] rewriting hardcoded OpenCode paths in markdown files"
  echo "profile:     $profile"
  echo "profile_dir: $profile_dir"
  echo "search:      $suffix"
  echo "replace:     $replacement_suffix"
  echo

  local files
  files="$(
    grep -rIl \
      --include='*.md' \
      --exclude-dir='.git' \
      --exclude-dir='node_modules' \
      --exclude-dir='.cache' \
      --exclude-dir='cache' \
      --exclude-dir='session' \
      --exclude-dir='tmp' \
      --exclude-dir='logs' \
      --exclude-dir='semantic' \
      --exclude-dir='index' \
      "$suffix" \
      "$profile_dir" || true
  )"

  [[ -n "$files" ]] || {
    echo "[ocp] no matching markdown files"
    return 0
  }

  echo "[ocp] files to update:"
  echo "$files"
  echo

  local escaped_search
  local escaped_replace

  escaped_search="$(printf '%s' "$suffix" | sed 's/[&/\]/\\&/g')"
  escaped_replace="$(printf '%s' "$replacement_suffix" | sed 's/[&/\]/\\&/g')"

  echo "$files" | while IFS= read -r file; do
    [[ -n "$file" ]] || continue

    sed -i "s|$escaped_search|$escaped_replace|g" "$file"
    echo "[updated] $file"
  done

  echo
  echo "[ocp] done"
}

install_bash_completion() {
  local cli_name="$1"
  local completions_dir="${BASH_COMPLETION_USER_DIR:-$HOME/.local/share/bash-completion/completions}"

  mkdir -p "$completions_dir"
  cmd_completion_bash "$cli_name" > "$completions_dir/$cli_name"

  echo "installed bash completion: $completions_dir/$cli_name"
}

install_zsh_completion() {
  local cli_name="$1"
  local completions_dir="${XDG_DATA_HOME:-$HOME/.local/share}/opencode-profile-kit/completions/zsh"
  local zshrc="${ZSHRC:-$HOME/.zshrc}"

  mkdir -p "$completions_dir"
  cmd_completion_zsh "$cli_name" > "$completions_dir/_$cli_name"

  echo "installed zsh completion: $completions_dir/_$cli_name"

  local marker_start="# opencode-profile-kit completion"

  if grep -qF "$marker_start" "$zshrc" 2>/dev/null; then
    echo "zshrc completion setup already exists: $zshrc"
    return 0
  fi

  cat >> "$zshrc" <<EOF

$marker_start
fpath=("$completions_dir" \$fpath)
autoload -Uz compinit
compinit
EOF

  echo "updated zshrc: $zshrc"
}


cmd_config() {
  cat <<CONFIG
CONFIG_DIR=$CONFIG_DIR
CONFIG_FILE=$CONFIG_FILE
DATA_DIR=$DATA_DIR
STATE_DIR=$STATE_DIR
PROFILES_DB=$PROFILES_DB
BINS_DB=$BINS_DB
OC_GLOBAL_DIR=$OC_GLOBAL_DIR
OC_PROFILES_DIR=$OC_PROFILES_DIR
OC_BIN_DIR=$OC_BIN_DIR
CONFIG
}

main() {
  local cmd="${1:-help}"; shift || true
  case "$cmd" in
    new) cmd_new "$@" ;;
    clone) cmd_clone "$@" ;;
    rename) cmd_rename "$@" ;;
    remove) cmd_remove "$@" ;;
    run) cmd_run "$@" ;;
    shell) cmd_shell "$@" ;;
    exec) cmd_exec "$@" ;;
    env) cmd_env "$@" ;;
    clear) cmd_clear "$@" ;;
    which) cmd_which "$@" ;;
    link) cmd_link "$@" ;;
    link-all) cmd_link_all "$@" ;;
    bin) cmd_bin "$@" ;;
    capture) cmd_capture "${1:-}" "${@:2}" ;;
    rewrite-paths) cmd_rewrite_paths "${1:-}" "${2:-/.config/opencode}" ;;
    list) cmd_list "$@" ;;
    path) cmd_path "$@" ;;
    refresh) cmd_refresh "$@" ;;
    doctor) cmd_doctor "$@" ;;
    completion) cmd_completion "$@" ;;
    config) cmd_config "$@" ;;
    help|-h|--help) usage ;;
    *) fail "unknown command: $cmd" ;;
  esac
}
main "$@"
